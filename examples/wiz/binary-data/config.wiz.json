{
    "$schema": "https://raw.githubusercontent.com/wiz-sh/compiler/main/packages/config/schemas/config.wiz.schema.json",
    "compiler": {
        "rootDir": ".",
        "outDir": "./dist",
        "runtimeChecks": "boundaries",
        "sourceMap": true
    },
    "files": {
        "include": [
            "*.wiz"
        ],
        "exclude": [
            "dist/**"
        ]
    }
}
