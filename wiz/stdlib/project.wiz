## Prints the owning Wiz project root for the current directory.
wiz_project_root(): path {
    wiz root
}

## Resolves an installed package or package subpath.
## @param package Package name and optional exported path.
wiz_package_path(string package): path {
    wiz resolve "$package"
}

## Requires an executable before continuing a script.
wiz_require_binary(string binary): status {
    wiz needs "$binary"
}

export -f wiz_project_root wiz_package_path wiz_require_binary
