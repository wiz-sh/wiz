# Modern file encryption, signatures, SSH keys, Java key stores, and NSS certificates.

declare command age(option?: "-R" | "-a" | "-d" | "-e" | "-i" | "-o" | "-p" | "-r" | "-s" | "--armor" | "--decrypt" | "--encrypt" | "--identity" | "--output" | "--passphrase" | "--plugin" | "--recipient" | "--recipients-file", value?: string, input?: file): status
declare command age-keygen(option?: "-o" | "-y" | "--convert" | "--output", value?: path, identityFile?: file): status
declare command minisign(option?: "-C" | "-G" | "-H" | "-Q" | "-R" | "-S" | "-V" | "-c" | "-m" | "-p" | "-P" | "-s" | "-t" | "-x", value?: string, input?: file): status
declare command ssh-keygen(option?: "-A" | "-B" | "-b" | "-C" | "-c" | "-D" | "-E" | "-e" | "-F" | "-f" | "-H" | "-i" | "-K" | "-k" | "-L" | "-l" | "-M" | "-m" | "-N" | "-n" | "-O" | "-P" | "-p" | "-Q" | "-R" | "-r" | "-S" | "-s" | "-t" | "-V" | "-v" | "-Y" | "-y", value?: string, keyFile?: file, ...files: file[]): status
declare command keytool(command?: "-certreq" | "-changealias" | "-delete" | "-exportcert" | "-genkeypair" | "-genseckey" | "-gencert" | "-importcert" | "-importpass" | "-importkeystore" | "-keypasswd" | "-list" | "-printcert" | "-printcertreq" | "-printcrl" | "-storepasswd", option?: "-alias" | "-cacerts" | "-dname" | "-ext" | "-file" | "-keyalg" | "-keypass" | "-keysize" | "-keystore" | "-noprompt" | "-providerclass" | "-providerpath" | "-rfc" | "-sigalg" | "-srcalias" | "-srckeystore" | "-srcstorepass" | "-storepass" | "-storetype" | "-trustcacerts" | "-v" | "-validity", value?: string): status
declare command certutil(option?: "-A" | "-B" | "-C" | "-D" | "-E" | "-F" | "-G" | "-H" | "-K" | "-L" | "-M" | "-N" | "-O" | "-R" | "-S" | "-U" | "-V" | "-W" | "-a" | "-c" | "-d" | "-f" | "-h" | "-i" | "-k" | "-m" | "-n" | "-o" | "-r" | "-s" | "-t" | "-v" | "-w" | "-x" | "-z", value?: string): status
