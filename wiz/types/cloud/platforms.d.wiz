# Application deployment platforms.

declare command flyctl(command: "apps" | "auth" | "certs" | "config" | "dashboard" | "deploy" | "doctor" | "extensions" | "image" | "ips" | "launch" | "logs" | "machine" | "machines" | "migrate-to-v2" | "orgs" | "platform" | "postgres" | "proxy" | "redis" | "regions" | "releases" | "scale" | "secrets" | "services" | "ssh" | "status" | "version" | "volumes", target?: string, option?: "--access-token" | "--app" | "--config" | "--image" | "--org" | "--region" | "--remote-only" | "--strategy" | "--yes", value?: string): status
declare command vercel(command?: "alias" | "bisect" | "blob" | "build" | "certs" | "deploy" | "dev" | "dns" | "domains" | "env" | "git" | "init" | "inspect" | "integration" | "link" | "list" | "login" | "logout" | "logs" | "project" | "promote" | "pull" | "redeploy" | "remove" | "rollback" | "switch" | "teams" | "whoami", target?: string, option?: "--archive" | "--build-env" | "--cwd" | "--env" | "--force" | "--local-config" | "--name" | "--prod" | "--scope" | "--token" | "--yes", value?: string): status
declare command netlify(command: "addons" | "api" | "build" | "completion" | "deploy" | "dev" | "env" | "functions" | "init" | "integration" | "link" | "lm" | "login" | "open" | "recipes" | "serve" | "sites" | "status" | "switch" | "unlink" | "watch", target?: string, option?: "--alias" | "--auth" | "--build" | "--context" | "--dir" | "--filter" | "--functions" | "--json" | "--prod" | "--site", value?: string): status
declare command heroku(command: string, target?: string, option?: "--app" | "--json" | "--remote" | "--team", value?: string, ...arguments: string[]): status
