# OCI-compatible container clients and image builders.

declare command podman(command: "attach" | "build" | "commit" | "compose" | "container" | "cp" | "create" | "diff" | "events" | "exec" | "export" | "generate" | "healthcheck" | "history" | "image" | "images" | "import" | "info" | "init" | "inspect" | "kill" | "load" | "login" | "logout" | "logs" | "machine" | "manifest" | "mount" | "network" | "pause" | "play" | "pod" | "port" | "ps" | "pull" | "push" | "rename" | "restart" | "rm" | "rmi" | "run" | "save" | "search" | "secret" | "start" | "stats" | "stop" | "system" | "tag" | "top" | "unmount" | "unpause" | "unshare" | "untag" | "update" | "version" | "volume" | "wait", target?: string, option?: "--all" | "--detach" | "--env" | "--file" | "--force" | "--format" | "--interactive" | "--name" | "--publish" | "--rm" | "--tag" | "--tty" | "--volume", value?: string, ...arguments: string[]): status
declare command nerdctl(command: "build" | "builder" | "commit" | "compose" | "container" | "cp" | "create" | "diff" | "events" | "exec" | "export" | "history" | "image" | "images" | "import" | "info" | "inspect" | "kill" | "load" | "login" | "logout" | "logs" | "network" | "pause" | "port" | "ps" | "pull" | "push" | "restart" | "rm" | "rmi" | "run" | "save" | "search" | "start" | "stats" | "stop" | "system" | "tag" | "top" | "unpause" | "update" | "version" | "volume" | "wait", target?: string, option?: "--all" | "--detach" | "--env" | "--file" | "--force" | "--format" | "--interactive" | "--name" | "--namespace" | "--publish" | "--rm" | "--tag" | "--tty" | "--volume", value?: string, ...arguments: string[]): status
declare command buildah(command: "add" | "build" | "commit" | "config" | "containers" | "copy" | "from" | "images" | "info" | "inspect" | "login" | "logout" | "manifest" | "mount" | "pull" | "push" | "rename" | "rm" | "rmi" | "run" | "source" | "tag" | "unmount" | "version", target?: string, option?: "--authfile" | "--file" | "--format" | "--name" | "--storage-driver" | "--tag" | "--tls-verify", value?: string, ...arguments: string[]): status
declare command skopeo(command: "copy" | "delete" | "generate-sigstore-key" | "inspect" | "list-tags" | "login" | "logout" | "manifest-digest" | "standalone-sign" | "standalone-verify" | "sync", source?: string, destination?: string, option?: "--all" | "--authfile" | "--creds" | "--format" | "--override-arch" | "--override-os" | "--src-tls-verify" | "--dest-tls-verify", value?: string): status
declare command docker-compose(command: "build" | "config" | "create" | "down" | "events" | "exec" | "images" | "kill" | "logs" | "pause" | "port" | "ps" | "pull" | "push" | "restart" | "rm" | "run" | "start" | "stop" | "top" | "unpause" | "up" | "version" | "wait" | "watch", service?: string, option?: "--abort-on-container-exit" | "--build" | "--detach" | "--env-file" | "--file" | "--force-recreate" | "--no-build" | "--no-deps" | "--no-recreate" | "--profile" | "--project-directory" | "--project-name" | "--remove-orphans" | "--scale" | "--timeout" | "--wait", value?: string, ...services: string[]): status
