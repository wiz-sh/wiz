# Additional version-control and forge clients.

declare command glab(command: "alias" | "api" | "auth" | "check-update" | "ci" | "cluster" | "completion" | "config" | "deploy-key" | "duo" | "incident" | "issue" | "label" | "mcp" | "milestone" | "mr" | "release" | "repo" | "schedule" | "securefile" | "snippet" | "ssh-key" | "stack" | "token" | "user" | "variable" | "version", target?: string, option?: "--group" | "--hostname" | "--output" | "--repo" | "--token" | "--web", value?: string): status
declare command hg(command: "add" | "annotate" | "archive" | "backout" | "bisect" | "bookmarks" | "branch" | "branches" | "bundle" | "cat" | "clone" | "commit" | "config" | "diff" | "export" | "files" | "forget" | "graft" | "grep" | "heads" | "help" | "identify" | "import" | "incoming" | "init" | "locate" | "log" | "merge" | "outgoing" | "paths" | "phase" | "pull" | "push" | "recover" | "remove" | "rename" | "resolve" | "revert" | "root" | "serve" | "shelve" | "status" | "summary" | "tag" | "tags" | "unbundle" | "unshelve" | "update" | "verify" | "version", target?: string, option?: "--branch" | "--date" | "--force" | "--include" | "--message" | "--repository" | "--rev" | "--template" | "--user", value?: string): status
