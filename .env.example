# Docker development defaults. Copy this file to .env for local work.
POSTGRES_DB=wiz_test
POSTGRES_USER=wiz_test
POSTGRES_PASSWORD=replace-with-a-development-password
DATABASE_URL=postgres://wiz_test:replace-with-a-development-password@localhost:55432/wiz_test
REGISTRY_HOST=0.0.0.0
REGISTRY_PORT=3000
REGISTRY_PUBLIC_URL=http://registry.test.localhost:53000
SESSION_SECRET=replace-with-at-least-32-random-characters
TOKEN_PEPPER=replace-with-at-least-32-random-characters
PASSWORD_PEPPER=replace-with-at-least-32-random-characters
WEBAUTHN_RP_ID=registry.test.localhost
WEBAUTHN_RP_NAME=Wiz Registry Development
WEBAUTHN_ORIGIN=http://registry.test.localhost:53000
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@registry.test.localhost
SMTP_FROM_NAME=Wiz Registry Development
STORAGE_DRIVER=s3
STORAGE_PATH=./apps/registry/data/archives
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=wiz-packages
S3_ACCESS_KEY_ID=replace-with-a-development-access-key
S3_SECRET_ACCESS_KEY=replace-with-a-development-secret-key
REDIS_URL=redis://redis:6379
RATE_LIMIT_AUTHENTICATION=1000
RATE_LIMIT_API=5000
RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=debug
LOG_FORMAT=json
CORS_ORIGINS=http://registry.test.localhost:53000
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE_SECONDS=600
OTEL_ENABLED=false
OTEL_SERVICE_NAME=wiz-registry-development
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_METRIC_EXPORT_INTERVAL=60000
REGISTRY_ADMIN_USERNAMES=
WIZ_REGISTRY_E2E_URL=http://localhost:53000
WIZ_MAILPIT_URL=http://localhost:58025
WIZ_E2E_KEEP_ENVIRONMENT=false

# Production Compose also requires these deployment values.
WIZ_REGISTRY_IMAGE=ghcr.io/your-organization/wiz-registry:latest
POSTGRES_PASSWORD_FILE=./secrets/postgres_password
REDIS_PASSWORD=replace-with-a-production-password
