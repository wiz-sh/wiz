{
    "name": "@wiz/pm",
    "version": "0.1.0",
    "private": true,
    "description": "Registry, Git, local, and workspace package management for Wiz",
    "license": "MIT",
    "author": "hazelcaffe",
    "keywords": [
        "bash",
        "shell",
        "package-manager",
        "git",
        "bun"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hazelcaffe/wiz.git",
        "directory": "packages/pm"
    },
    "homepage": "https://github.com/hazelcaffe/wiz#readme",
    "bugs": {
        "url": "https://github.com/hazelcaffe/wiz/issues"
    },
    "type": "module",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "schemas"
    ],
    "scripts": {
        "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm && tsc --project ./tsconfig.build.json"
    },
    "dependencies": {
        "@wiz/registry-client": "workspace:*"
    },
    "engines": {
        "bun": ">=1.2.0"
    }
}
