{
    "name": "@wiz/registry",
    "version": "0.1.0",
    "private": true,
    "description": "Self-hostable Wiz package registry API and worker",
    "license": "MIT",
    "type": "module",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "bun build ./src/server.ts ./src/index.ts --outdir ./dist --target bun --format esm && tsc --project ./tsconfig.build.json",
        "dev": "bun --watch src/server.ts",
        "db:check": "bunx drizzle-kit check",
        "db:generate": "bunx drizzle-kit generate",
        "infra:down": "docker compose down",
        "infra:up": "docker compose up -d --wait",
        "migrate": "bun src/database/migrate.ts",
        "test:integration": "bun run migrate && bun test tests/database.test.ts tests/email.test.ts",
        "worker": "bun src/worker.ts"
    },
    "dependencies": {
        "@elysia/cors": "^1.4.2",
        "@elysia/opentelemetry": "^1.4.12",
        "@elysiajs/openapi": "^1.4.15",
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
        "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
        "@opentelemetry/sdk-metrics": "^2.9.0",
        "@simplewebauthn/server": "^13.3.2",
        "@wiz/registry-client": "workspace:*",
        "drizzle-orm": "^0.45.2",
        "elysia": "^1.4.29",
        "nodemailer": "^7.0.13"
    },
    "devDependencies": {
        "@types/nodemailer": "^7.0.11",
        "drizzle-kit": "^0.31.10"
    }
}
