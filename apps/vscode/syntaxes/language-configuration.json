{
    "comments": {
        "lineComment": "#"
    },
    "wordPattern": "(-?[0-9]+(?:\\.[0-9]+)?)|([A-Za-z_][A-Za-z0-9_-]*)",
    "brackets": [
        [
            "{",
            "}"
        ],
        [
            "(",
            ")"
        ],
        [
            "[",
            "]"
        ]
    ],
    "autoClosingPairs": [
        {
            "open": "{",
            "close": "}"
        },
        {
            "open": "(",
            "close": ")"
        },
        {
            "open": "[",
            "close": "]"
        },
        {
            "open": "\"",
            "close": "\"",
            "notIn": [
                "string"
            ]
        },
        {
            "open": "'",
            "close": "'",
            "notIn": [
                "string",
                "comment"
            ]
        }
    ],
    "surroundingPairs": [
        [
            "{",
            "}"
        ],
        [
            "(",
            ")"
        ],
        [
            "[",
            "]"
        ],
        [
            "\"",
            "\""
        ],
        [
            "'",
            "'"
        ]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*(?:if|for|while|until|case|[A-Za-z_][A-Za-z0-9_]*\\s*\\([^)]*\\)\\s*\\{)",
            "end": "^\\s*(?:fi|done|esac|\\})"
        }
    },
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(?:(?:if|elif)\\b.*(?:;\\s*)?then\\s*$|(?:for|while|until)\\b.*(?:;\\s*)?do\\s*$|case\\b.*\\bin\\s*$|[A-Za-z_][A-Za-z0-9_]*\\s*\\([^)]*\\)(?:\\s*:\\s*[A-Za-z_][A-Za-z0-9_?\\[\\]<> ,]*)?\\s*\\{\\s*)$",
        "decreaseIndentPattern": "^\\s*(?:fi|done|esac|\\})\\s*(?:#.*)?$"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*##.*$",
            "action": {
                "indentAction": "none",
                "appendText": "## "
            }
        },
        {
            "beforeText": "^.*\\{\\s*$",
            "afterText": "^\\s*\\}",
            "action": {
                "indentAction": "indentOutdent"
            }
        }
    ]
}
