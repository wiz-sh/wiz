{
    "Typed variable": {
        "prefix": "declareT",
        "body": [
            "declare -T ${1:string} ${2:name}=\"${3:value}\""
        ],
        "description": "Declare a typed Wiz variable"
    },
    "Documented typed function": {
        "prefix": "tfunction",
        "body": [
            "## ${1:Describe what this function guarantees.}",
            "## @param ${2:name} ${3:Describe the parameter.}",
            "## @returns ${4:Describe the result channel.}",
            "${5:function_name}(${6:string} ${2:name}): ${7:status} {",
            "    ${0:return 0}",
            "}"
        ],
        "description": "Create a documented typed shell function"
    },
    "External command declaration": {
        "prefix": "dcommand",
        "body": [
            "## ${1:Describe the external command.}",
            "declare command ${2:name}(${3:path: path, option?: string, value?: string}): ${4:status}"
        ],
        "description": "Declare an external command in a .d.wiz file"
    },
    "Type package import": {
        "prefix": "sourceT",
        "body": [
            "source -T \"${1:@types/common/git}\""
        ],
        "description": "Import an installed declaration package without runtime output"
    },
    "Scoped module import": {
        "prefix": "sourceI",
        "body": [
            "source -I ${1:name} -- \"${2:./module.wiz}\""
        ],
        "description": "Import selected exported names from an isolated Wiz module"
    },
    "Environment declaration": {
        "prefix": "denv",
        "body": [
            "declare env ${1:NAME}${2:?}: ${3:string}"
        ],
        "description": "Declare a typed environment variable"
    }
}
