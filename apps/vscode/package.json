{
    "name": "wiz-language",
    "displayName": "Wiz Language",
    "description": "Typed shell language support for Wiz",
    "version": "0.1.0",
    "private": true,
    "license": "MIT",
    "publisher": "wiz",
    "repository": {
        "type": "git",
        "url": "https://github.com/hazelcaffe/wiz.git",
        "directory": "apps/vscode"
    },
    "homepage": "https://github.com/hazelcaffe/wiz#readme",
    "bugs": {
        "url": "https://github.com/hazelcaffe/wiz/issues"
    },
    "engines": {
        "vscode": "^1.95.0"
    },
    "categories": [
        "Programming Languages",
        "Linters",
        "Formatters"
    ],
    "keywords": [
        "bash",
        "shell",
        "typed shell",
        "wiz"
    ],
    "extensionKind": [
        "workspace"
    ],
    "capabilities": {
        "untrustedWorkspaces": {
            "supported": false,
            "description": "Wiz runs project shell commands and therefore requires a trusted workspace."
        },
        "virtualWorkspaces": false
    },
    "activationEvents": [
        "onLanguage:wiz",
        "workspaceContains:config.wiz.json"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "wiz",
                "aliases": [
                    "Wiz",
                    "Typed Shell"
                ],
                "extensions": [
                    ".wiz",
                    ".d.wiz"
                ],
                "icon": {
                    "light": "./media/wiz-light.svg",
                    "dark": "./media/wiz-dark.svg"
                },
                "configuration": "./syntaxes/language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "wiz",
                "scopeName": "source.wiz",
                "path": "./syntaxes/wiz.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "wiz",
                "path": "./syntaxes/wiz.code-snippets.json"
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "wiz",
                "scopes": {
                    "comment": [
                        "comment.line.number-sign.wiz"
                    ],
                    "function": [
                        "entity.name.function.wiz"
                    ],
                    "string": [
                        "string.quoted.wiz"
                    ],
                    "number": [
                        "constant.numeric.wiz"
                    ],
                    "operator": [
                        "keyword.operator.wiz"
                    ],
                    "parameter": [
                        "variable.parameter.wiz"
                    ],
                    "variable": [
                        "variable.other.wiz"
                    ]
                }
            }
        ],
        "commands": [
            {
                "command": "wiz.restartLanguageServer",
                "title": "Wiz: Restart Language Server"
            },
            {
                "command": "wiz.formatDocument",
                "title": "Wiz: Format Document",
                "enablement": "editorLangId == wiz"
            },
            {
                "command": "wiz.lintFix",
                "title": "Wiz: Lint and Fix",
                "enablement": "editorLangId == wiz"
            },
            {
                "command": "wiz.build",
                "title": "Wiz: Build Project"
            },
            {
                "command": "wiz.check",
                "title": "Wiz: Check Project"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "wiz.formatDocument",
                    "when": "editorLangId == wiz",
                    "group": "1_modification@10"
                },
                {
                    "command": "wiz.lintFix",
                    "when": "editorLangId == wiz",
                    "group": "1_modification@11"
                }
            ]
        },
        "configuration": {
            "title": "Wiz",
            "properties": {
                "wiz.server.path": {
                    "type": "string",
                    "default": "wiz",
                    "description": "Path to the Wiz executable used to start the Wiz language server."
                },
                "wiz.server.trace": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Controls JSON-RPC tracing in the Wiz language-server output channel."
                },
                "wiz.commands.revealTerminal": {
                    "type": "boolean",
                    "default": true,
                    "description": "Reveal the shared Wiz terminal when running build, check, or lint commands."
                }
            }
        },
        "configurationDefaults": {
            "[wiz]": {
                "editor.defaultFormatter": "wiz.wiz-language",
                "editor.formatOnSave": true,
                "editor.semanticHighlighting.enabled": true,
                "editor.insertSpaces": true,
                "editor.tabSize": 4,
                "editor.bracketPairColorization.enabled": true,
                "editor.guides.bracketPairs": "active"
            }
        }
    },
    "scripts": {
        "build": "bun build ./src/extension.ts --outfile ./dist/extension.js --target node --format cjs --external vscode",
        "package": "bun x --package @vscode/vsce vsce package --no-dependencies",
        "test": "bun test"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/vscode": "^1.95.0"
    }
}
