{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "declaration": true,
        "emitDeclarationOnly": true,
        "noEmit": false,
        "outDir": "./dist",
        "rootDir": "./src",
        "paths": {
            "@wiz/pm": [
                "../../packages/pm/dist/index.d.ts"
            ],
            "@wiz/runtime": [
                "../../packages/runtime/dist/index.d.ts"
            ],
            "@wiz/compiler": [
                "../../packages/compiler/dist/index.d.ts"
            ],
            "@wiz/config": [
                "../../packages/config/dist/index.d.ts"
            ],
            "@wiz/formatter": [
                "../../packages/formatter/dist/index.d.ts"
            ],
            "@wiz/linter": [
                "../../packages/linter/dist/index.d.ts"
            ],
            "@wiz/lsp": [
                "../../packages/lsp/dist/index.d.ts"
            ]
        }
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "tests"
    ]
}
