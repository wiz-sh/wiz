{
    "name": "@wiz-sh/wiz",
    "version": "0.1.0",
    "description": "Typed shell tooling and multi-source package management for shell projects",
    "license": "MIT",
    "author": "hazelcaffe",
    "keywords": [
        "bash",
        "shell",
        "package-manager",
        "git",
        "bun"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wiz-sh/wiz.git",
        "directory": "apps/cli"
    },
    "homepage": "https://github.com/wiz-sh/wiz#readme",
    "bugs": {
        "url": "https://github.com/wiz-sh/wiz/issues"
    },
    "type": "module",
    "bin": {
        "wiz": "./dist/cli.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "bun build ./src/cli.ts --outdir ./dist --target bun --format esm && tsc --project ./tsconfig.build.json"
    },
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "bun": ">=1.2.0"
    },
    "dependencies": {
        "@wiz-sh/compiler": "^0.1.0",
        "@wiz-sh/config": "^0.1.0",
        "@wiz-sh/formatter": "^0.1.0",
        "@wiz-sh/linter": "^0.1.0",
        "@wiz-sh/lsp": "^0.1.0",
        "@wiz-sh/pm": "^0.1.0",
        "@wiz-sh/registry-client": "^0.1.0",
        "@wiz-sh/runtime": "^0.1.0",
        "chalk": "^5.6.2"
    }
}
