{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "noImplicitOverride": true,
        "verbatimModuleSyntax": true,
        "allowImportingTsExtensions": true,
        "paths": {
            "@wiz-sh/compiler": [
                "../compiler/packages/compiler/src/index.ts"
            ],
            "@wiz-sh/config": [
                "../compiler/packages/config/src/index.ts"
            ],
            "@wiz-sh/formatter": [
                "../linter/packages/formatter/src/index.ts"
            ],
            "@wiz-sh/language-service": [
                "../lsp/packages/language-service/src/index.ts"
            ],
            "@wiz-sh/linter": [
                "../linter/packages/linter/src/index.ts"
            ],
            "@wiz-sh/lsp": [
                "../lsp/packages/lsp/src/index.ts"
            ],
            "@wiz-sh/pm": [
                "../package-manager/packages/pm/src/index.ts"
            ],
            "@wiz-sh/registry-client": [
                "../registry/packages/registry-client/src/index.ts"
            ],
            "@wiz-sh/runtime": [
                "../package-manager/packages/runtime/src/index.ts"
            ],
            "@wiz-sh/types/*": [
                "../types/wiz/types/*"
            ]
        },
        "noEmit": true,
        "types": [
            "bun-types"
        ]
    },
    "include": [
        "apps/**/*.ts",
        "examples/**/*.ts",
        "tests/**/*.ts",
        "tools/**/*.ts"
    ],
    "exclude": [
        "**/dist",
        "**/node_modules"
    ]
}
